<?php

/**
 * @file
 * Hooks for the Vault Extra module: expiration, storage usage, favorites
 * and sharing for the Secure File Vault.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Field\FieldDefinitionInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\Core\TypedData\TypedDataInterface;
use Drupal\node\NodeInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_help().
 */
function vault_extra_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.vault_extra') {
    return '<p>' . t('Adds file expiration dates, per-user storage usage, favorites and file sharing to the Secure File Vault content type.') . '</p>';
  }
}

/**
 * Implements hook_theme().
 */
function vault_extra_theme($existing, $type, $theme, $path) {
  return [
    'vault_extra_storage_usage' => [
      'variables' => [
        'used_formatted' => NULL,
        'quota_formatted' => NULL,
        'percent' => 0,
        'severity' => 'normal',
        'plan_label' => NULL,
        'price_formatted' => NULL,
      ],
    ],
    'vault_extra_file_list' => [
      'variables' => [
        'empty_message' => NULL,
        'items' => [],
      ],
    ],
    'vault_extra_landing' => [
      'variables' => [
        'is_authenticated' => FALSE,
        'primary_cta' => NULL,
        'secondary_cta' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_page_attachments().
 *
 * Loads the vault theme CSS on every front-end page, not just the pages
 * this module renders directly, so core pages (login, register, node
 * forms) get the same branding. Deliberately excluded from the admin
 * theme (Claro) so the backend keeps its standard, unbranded look.
 */
function vault_extra_page_attachments(array &$attachments) {
  if (\Drupal::theme()->getActiveTheme()->getName() === \Drupal::config('system.theme')->get('default')) {
    $attachments['#attached']['library'][] = 'vault_extra/vault_extra';
  }
}

/**
 * Implements hook_node_access().
 *
 * The vault_file content type must stay private: without this, any
 * authenticated user with the core "access content" permission could view
 * any published node. We forbid viewing for everyone except the owner,
 * users the file has been explicitly shared with, and roles granted the
 * core "bypass node access" permission (checked by core before this hook
 * even runs). Edit/delete are already correctly restricted to the owner
 * by node module's own "edit own"/"delete own" permission logic, so we
 * only need to intervene for the "view" operation.
 */
function vault_extra_node_access(NodeInterface $node, $op, AccountInterface $account) {
  if ($node->bundle() !== 'vault_file' || $op !== 'view') {
    return AccessResult::neutral();
  }

  if ((int) $node->getOwnerId() === (int) $account->id()) {
    return AccessResult::allowed()->cachePerUser()->addCacheableDependency($node);
  }

  $shared = \Drupal::database()->select('vault_extra_share', 's')
    ->fields('s', ['id'])
    ->condition('nid', $node->id())
    ->condition('shared_with_uid', $account->id())
    ->range(0, 1)
    ->execute()
    ->fetchField();

  if ($shared) {
    return AccessResult::allowed()->cachePerUser()->setCacheMaxAge(0);
  }

  return AccessResult::forbidden()->cachePerUser()->addCacheableDependency($node);
}

/**
 * Implements hook_file_download().
 *
 * Enforces the same owner/shared/admin rule as vault_extra_node_access()
 * on the actual private file download, since a node access grant does not
 * automatically grant access to the file entity behind it.
 */
function vault_extra_file_download($uri) {
  if (!str_starts_with($uri, 'private://')) {
    return NULL;
  }

  /** @var \Drupal\file\FileInterface[] $files */
  $files = \Drupal::entityTypeManager()->getStorage('file')->loadByProperties(['uri' => $uri]);
  if (!$files) {
    return NULL;
  }
  $file = reset($files);

  $usage = \Drupal::service('file.usage')->listUsage($file);
  if (empty($usage['file']['node'])) {
    return NULL;
  }
  $nid = key($usage['file']['node']);
  $node = \Drupal::entityTypeManager()->getStorage('node')->load($nid);
  if (!$node || $node->bundle() !== 'vault_file') {
    return NULL;
  }

  $account = \Drupal::currentUser();
  if ($account->hasPermission('bypass node access')) {
    return ['Content-Disposition' => 'attachment; filename="' . $file->getFilename() . '"'];
  }
  if ((int) $node->getOwnerId() === (int) $account->id()) {
    return ['Content-Disposition' => 'attachment; filename="' . $file->getFilename() . '"'];
  }

  $shared = \Drupal::database()->select('vault_extra_share', 's')
    ->fields('s', ['id'])
    ->condition('nid', $node->id())
    ->condition('shared_with_uid', $account->id())
    ->range(0, 1)
    ->execute()
    ->fetchField();

  if ($shared) {
    return ['Content-Disposition' => 'attachment; filename="' . $file->getFilename() . '"'];
  }

  return -1;
}

/**
 * Implements hook_cron().
 *
 * Unpublishes vault_file nodes whose expiration date has passed.
 */
function vault_extra_cron() {
  $today = \Drupal::time()->getRequestTime();
  $storage = \Drupal::entityTypeManager()->getStorage('node');

  $nids = $storage->getQuery()
    ->condition('type', 'vault_file')
    ->condition('status', 1)
    ->condition('field_expiration_date', date('Y-m-d', $today), '<')
    ->accessCheck(FALSE)
    ->execute();

  if (!$nids) {
    return;
  }

  $logger = \Drupal::logger('vault_extra');
  foreach ($storage->loadMultiple($nids) as $node) {
    $node->setUnpublished();
    $node->save();
    $logger->notice('Unpublished expired vault file %title (nid %nid).', [
      '%title' => $node->label(),
      '%nid' => $node->id(),
    ]);
  }
}

/**
 * Implements hook_user_view().
 *
 * Adds a storage usage summary to the user's own profile page.
 */
function vault_extra_user_view(array &$build, UserInterface $account, $display, $view_mode) {
  if ($view_mode !== 'full') {
    return;
  }
  if ((int) \Drupal::currentUser()->id() !== (int) $account->id() && !\Drupal::currentUser()->hasPermission('administer users')) {
    return;
  }

  /** @var \Drupal\vault_extra\Service\StorageCalculator $calculator */
  $calculator = \Drupal::service('vault_extra.storage_calculator');
  $uid = (int) $account->id();
  $used = $calculator->getUsedBytes($uid);
  $plan = $calculator->getPlan($uid);
  $quota = $plan ? $plan->getStorageLimitBytes() : \Drupal\vault_extra\Service\StorageCalculator::FALLBACK_QUOTA_BYTES;
  $percent = $quota > 0 ? min(100, (int) round(($used / $quota) * 100)) : 0;

  $severity = 'normal';
  if ($percent >= 100) {
    $severity = 'full';
  }
  elseif ($percent >= 80) {
    $severity = 'warning';
  }

  $build['vault_storage_usage'] = [
    '#theme' => 'vault_extra_storage_usage',
    '#used_formatted' => format_size($used),
    '#quota_formatted' => format_size($quota),
    '#percent' => $percent,
    '#severity' => $severity,
    '#plan_label' => $plan ? $plan->label() : NULL,
    '#price_formatted' => $plan && $plan->getPriceUsd() > 0 ? sprintf('$%.2f / mo', $plan->getPriceUsd()) : t('Free'),
    '#weight' => -10,
  ];
}

/**
 * Implements hook_form_FORM_ID_alter() for the vault_file node form.
 *
 * Enforces a per-user storage quota at upload time.
 */
function vault_extra_form_node_vault_file_form_alter(array &$form, FormStateInterface $form_state) {
  $form['#validate'][] = 'vault_extra_node_form_quota_validate';
}

/**
 * Form validation handler: rejects uploads that would exceed the user's
 * storage quota.
 */
function vault_extra_node_form_quota_validate(array &$form, FormStateInterface $form_state) {
  $fids = $form_state->getValue(['field_vault_document', 0, 'fids']);
  if (empty($fids)) {
    return;
  }
  $file = \Drupal::entityTypeManager()->getStorage('file')->load(reset($fids));
  if (!$file) {
    return;
  }

  /** @var \Drupal\node\NodeInterface|null $node */
  $node = $form_state->getFormObject()->getEntity();
  $uid = (int) \Drupal::currentUser()->id();

  /** @var \Drupal\vault_extra\Service\StorageCalculator $calculator */
  $calculator = \Drupal::service('vault_extra.storage_calculator');
  $used = $calculator->getUsedBytes($uid);

  // Exclude the file already attached to this node when re-saving.
  if ($node && !$node->isNew() && !$node->get('field_vault_document')->isEmpty()) {
    $existing = $node->get('field_vault_document')->entity;
    if ($existing && (int) $existing->id() === (int) $file->id()) {
      return;
    }
  }

  if ($used + (int) $file->getSize() > $calculator->getQuotaBytes($uid)) {
    $form_state->setErrorByName('field_vault_document', t('This upload would exceed your storage quota of %quota. You have used %used so far. Upgrade your plan to store larger files.', [
      '%quota' => format_size($calculator->getQuotaBytes($uid)),
      '%used' => format_size($used),
    ]));
  }
}

/**
 * Implements hook_preprocess_node() for vault_file nodes.
 *
 * Adds an expiration status badge (expired / expiring soon) to the node
 * render array for use in templates.
 */
function vault_extra_preprocess_node(array &$variables) {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];
  if ($node->bundle() !== 'vault_file' || $node->get('field_expiration_date')->isEmpty()) {
    return;
  }

  $expiration = $node->get('field_expiration_date')->date;
  if (!$expiration) {
    return;
  }
  $now = new DateTime('now', $expiration->getTimezone());
  $diff_days = (int) $now->diff($expiration->getPhpDateTime())->format('%r%a');

  if ($diff_days < 0) {
    $variables['vault_expiration_badge'] = ['label' => t('Expired'), 'class' => 'vault-extra-badge--expired'];
  }
  elseif ($diff_days <= 7) {
    $variables['vault_expiration_badge'] = ['label' => t('Expires in @days days', ['@days' => $diff_days]), 'class' => 'vault-extra-badge--expiring-soon'];
  }
}

/**
 * Implements hook_entity_field_access().
 *
 * Only an account with 'administer vault plans' may change a user's
 * assigned plan. Anyone who can already view the user's profile may see
 * which plan they're on (it's shown alongside storage usage).
 */
function vault_extra_entity_field_access($operation, FieldDefinitionInterface $field_definition, AccountInterface $account, ?TypedDataInterface $items = NULL) {
  if ($field_definition->getName() !== 'field_vault_plan') {
    return AccessResult::neutral();
  }

  if ($operation === 'edit') {
    // AccessResult::allowedIfHasPermission() would only return ALLOWED or
    // NEUTRAL — never FORBIDDEN — and Drupal's field access aggregation
    // treats an all-neutral vote as allowed by default. We must return an
    // explicit forbidden to actually block non-admins from editing this.
    return $account->hasPermission('administer vault plans')
      ? AccessResult::allowed()
      : AccessResult::forbidden('Only accounts with the administer vault plans permission may change a user\'s plan.');
  }

  return AccessResult::neutral();
}
